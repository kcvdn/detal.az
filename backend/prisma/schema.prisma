model User {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(STAFF)
  created_by  Int?
  createdAt   DateTime @default(now())
}

model Seller {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  products  Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  description String?
  seller_id   Int
  created_by  Int
  createdAt   DateTime @default(now())

  seller Seller @relation(fields: [seller_id], references: [id])
}

enum Role {
  ADMIN
  STAFF
  VIEWER
}